# ---------------------------------------------------------------------------
# Beacon environment configuration
# Copy to `.env` and fill in as needed. Every value has a sensible default,
# so Beacon runs in "demo mode" with zero configuration.
# ---------------------------------------------------------------------------

# --- Core ---
NODE_ENV=development

# --- API service (apps/api) ---
PORT=4000
HOST=0.0.0.0
CORS_ORIGIN=*
CACHE_TTL_SECONDS=3600

# --- Database (optional) ---
# When unset, the API runs stateless (analyses are computed on the fly and
# cached in memory). Set this to enable persistence + history.
# docker-compose provides: postgresql://beacon:beacon@localhost:5432/beacon
DATABASE_URL=

# --- Redis cache (optional) ---
# When unset, an in-memory cache is used instead.
# docker-compose provides: redis://localhost:6379
REDIS_URL=

# --- GitHub API ---
# A personal access token (classic or fine-grained, public-repo read is enough).
# Strongly recommended: unauthenticated GitHub requests are limited to 60/hour.
GITHUB_TOKEN=

# GitHub OAuth (for the authenticated dashboard experience — optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- AI summary provider ---
# One of: heuristic (default, offline, no key) | openai | anthropic
BEACON_AI_PROVIDER=heuristic
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Web dashboard (apps/web) ---
# Point the dashboard at the API. When empty, the dashboard uses local demo data.
NEXT_PUBLIC_API_URL=http://localhost:4000
