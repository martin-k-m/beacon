{
  "name": "beacon",
  "version": "1.2.0",
  "private": true,
  "description": "Open-source GitHub repository intelligence platform.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/martin-k-m/beacon.git"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json}\"",
    "clean": "turbo run clean && rimraf node_modules",
    "db:generate": "npm run generate --workspace @beacon/database",
    "db:migrate": "npm run migrate --workspace @beacon/database",
    "db:seed": "npm run seed --workspace @beacon/database"
  },
  "overrides": {
    "postcss": "^8.5.12",
    "sharp": "0.35.0"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.0.0"
}
