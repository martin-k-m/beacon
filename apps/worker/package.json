{
  "name": "@beacon/worker",
  "version": "0.1.0",
  "description": "Background worker that consumes Beacon analysis jobs from Redis (BullMQ).",
  "private": true,
  "license": "MIT",
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "clean": "rimraf dist"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@beacon/analytics": "*",
    "@beacon/database": "*",
    "@beacon/shared": "*",
    "bullmq": "^5.34.0",
    "ioredis": "^5.4.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@beacon/config": "*",
    "@types/node": "^20.17.10",
    "eslint": "^8.57.1",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
