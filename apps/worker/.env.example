# Beacon worker — environment configuration
# Every value is optional. With no REDIS_URL set, the worker idles (the API
# processes analyses inline instead) rather than crashing.

# --- Queue (Redis) ---
# When set, the worker consumes analysis jobs from this Redis instance.
# REDIS_URL=redis://localhost:6379

# --- Persistence (optional) ---
# When set, completed analyses are stored in Postgres via @beacon/database.
# DATABASE_URL=postgresql://user:password@localhost:5432/beacon?schema=public

# --- GitHub (optional but recommended) ---
# Without a token, live analysis uses low unauthenticated rate limits.
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# --- AI summaries ---
# One of: heuristic (default, offline) | openai | anthropic
BEACON_AI_PROVIDER=heuristic
# OPENAI_API_KEY=sk-xxxxxxxx
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# --- Concurrency ---
# Number of jobs a single worker instance processes concurrently.
WORKER_CONCURRENCY=4

NODE_ENV=development
