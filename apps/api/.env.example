# Beacon API — environment configuration
# Every value is optional. With none of these set, the API still starts and
# `GET /api/demo` works (in-memory cache, no persistence, heuristic AI).

# --- Server ---
PORT=4000
HOST=0.0.0.0
NODE_ENV=development

# --- Persistence (optional) ---
# When set, analyses are stored in Postgres via @beacon/database.
# DATABASE_URL=postgresql://user:password@localhost:5432/beacon

# --- Cache (optional) ---
# When set, a Redis-backed cache is used; otherwise an in-memory cache.
# REDIS_URL=redis://localhost:6379
CACHE_TTL_SECONDS=3600

# --- GitHub (optional but recommended) ---
# Without a token, live analysis uses low unauthenticated rate limits.
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# --- Embeds (optional) ---
# Public base URL used to build widget/badge embed snippets. Defaults to
# http://localhost:${PORT}. BEACON_HOST is accepted as an alias.
# PUBLIC_URL=https://beacon.example.com
# BEACON_HOST=https://beacon.example.com

# --- GitHub App webhooks (optional) ---
# When set, POST /api/github/webhooks verifies the X-Hub-Signature-256 HMAC.
# Without it, verification is skipped (dev mode) but events are still processed.
# GITHUB_WEBHOOK_SECRET=your-webhook-secret
# GitHub App credentials — architecture-ready for authenticated installs.
# GITHUB_APP_ID=123456
# GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# --- AI summaries ---
# One of: heuristic (default, offline) | openai | anthropic
BEACON_AI_PROVIDER=heuristic
# OPENAI_API_KEY=sk-xxxxxxxx
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# --- CORS ---
# "*" (default) reflects any origin; or a comma-separated allow-list.
CORS_ORIGIN=*
