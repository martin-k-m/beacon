{
  "name": "@beacon/api",
  "version": "0.1.0",
  "description": "Fastify HTTP API for Beacon — GitHub repository intelligence.",
  "private": true,
  "license": "MIT",
  "type": "commonjs",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@beacon/analytics": "*",
    "@beacon/core": "*",
    "@beacon/database": "*",
    "@beacon/widgets": "*",
    "@fastify/cors": "^10.0.1",
    "fastify": "^5.1.0",
    "ioredis": "^5.4.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@beacon/config": "*",
    "@types/node": "^20.17.10",
    "eslint": "^8.57.1",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
