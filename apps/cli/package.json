{
  "name": "@beacon/cli",
  "version": "0.1.0",
  "description": "Analyze the health of any GitHub repository from your terminal.",
  "license": "MIT",
  "private": false,
  "type": "commonjs",
  "bin": {
    "beacon": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run",
    "clean": "rimraf dist"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@beacon/core": "*",
    "commander": "^12.1.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@beacon/config": "*",
    "@types/node": "^20.17.10",
    "eslint": "^8.57.1",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
