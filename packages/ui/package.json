{
  "name": "@beacon/ui",
  "version": "0.1.0",
  "description": "Shared React UI primitives for Beacon apps (dashboard + web).",
  "license": "MIT",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./utils": {
      "types": "./src/utils.ts",
      "default": "./src/utils.ts"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "clean": "rimraf .turbo"
  },
  "dependencies": {
    "@beacon/shared": "*",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.5.4"
  },
  "peerDependencies": {
    "framer-motion": ">=11",
    "lucide-react": ">=0.4",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@beacon/config": "*",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "eslint": "^8.57.1",
    "framer-motion": "^11.11.0",
    "lucide-react": "^0.454.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.3"
  }
}
