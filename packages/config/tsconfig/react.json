{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Beacon React App",
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "preserve",
    "allowJs": true,
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    "isolatedModules": true
  }
}
