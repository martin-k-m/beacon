{
  "name": "@beacon/sdk",
  "version": "0.1.0",
  "description": "Programmatic client for Beacon repository intelligence.",
  "license": "MIT",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/beacon/beacon.git",
    "directory": "packages/sdk"
  },
  "keywords": [
    "beacon",
    "github",
    "repository-health",
    "analytics",
    "sdk"
  ],
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@beacon/shared": "*",
    "@beacon/analytics": "*",
    "@beacon/github": "*"
  },
  "devDependencies": {
    "@beacon/config": "*",
    "@beacon/ai": "*",
    "@types/node": "^20.17.10",
    "eslint": "^8.57.1",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.3",
    "vitest": "^3.2.6"
  }
}
