{
  "name": "@beacon/database",
  "version": "0.1.0",
  "description": "Prisma schema and client for Beacon.",
  "license": "MIT",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "prisma"
  ],
  "scripts": {
    "generate": "prisma generate",
    "build": "prisma generate && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "migrate": "prisma migrate deploy",
    "migrate:dev": "prisma migrate dev",
    "push": "prisma db push",
    "seed": "tsx src/seed.ts",
    "studio": "prisma studio",
    "lint": "eslint \"src/**/*.ts\"",
    "clean": "rimraf dist"
  },
  "prisma": {
    "seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "@beacon/ai": "*",
    "@beacon/analytics": "*",
    "@beacon/config": "*",
    "@beacon/shared": "*",
    "@types/node": "^20.17.10",
    "eslint": "^8.57.1",
    "prisma": "^5.22.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
